@page "/admin/news"
@layout AdminLayout
@attribute [Authorize(Policy = "Admin")]

<PageTitle>News - Admin - Silverbridge Harps</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">News Management</MudText>
    <MudAlert Severity="Severity.Info">
        News management will be available here. You can create, edit, and publish articles, and push to social media.
    </MudAlert>
</MudContainer>
